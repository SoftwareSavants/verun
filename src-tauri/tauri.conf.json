{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Verun",
  "version": "0.10.0",
  "identifier": "com.softwaresavants.verun",
  "build": {
    "beforeDevCommand": "node src-tauri/scripts/copy-relay-sidecar.mjs && pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node src-tauri/scripts/copy-relay-sidecar.mjs && pnpm build",
    "beforeBundleCommand": "node src-tauri/scripts/copy-relay-sidecar.mjs",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Verun",
        "width": 1600,
        "height": 1000,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["/**"],
          "requireLiteralLeadingDot": false
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/lsp/node_modules/**/*"
    ],
    "externalBin": [
      "binaries/verun-mcp-relay"
    ],
    "createUpdaterArtifacts": true,
    "macOS": {
      "dmg": {
        "windowSize": {
          "width": 594,
          "height": 456
        },
        "appPosition": {
          "x": 160,
          "y": 145
        },
        "applicationFolderPosition": {
          "x": 380,
          "y": 145
        }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "sql": {
      "preload": ["sqlite:verun.db"]
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY3Qzc2NEUxNkU3ODQ3OTEKUldTUlIzaHU0V1RIWisrYUJrSzBqL3BlZnBkd3pUcDlMTEE2SFR2eDkzN3pYL2JQNzk4ZC9JUWMK",
      "endpoints": [
        "https://github.com/SoftwareSavants/verun/releases/latest/download/latest.json"
      ]
    }
  }
}
